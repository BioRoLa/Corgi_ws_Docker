{
    "name": "Corgi ROS 2 Development (Pack & Go)",
    "image": "starlee0514/corgi_ros2_pack_and_go:latest",
    // 啟動參數：對齊 launch.sh，包含 GPU 與 X11 支援
    "runArgs": [
        "--gpus=all",
        "--net=host",
        "--privileged",
        "--shm-size=8g",
        "--name",
        "corgi_dev_${localEnv:USER}"
    ],
    // 設置容器內的工作目錄
    "workspaceFolder": "/root/corgi_ws",
    // 掛載設定
    "mounts": [
        // 1. 將目前的母倉庫掛載到容器內的 /root/corgi_ws
        {
            "source": "${localWorkspaceFolder}",
            "target": "/root/corgi_ws",
            "type": "bind"
        },
        // 2. 掛載 X11 Socket 以啟動 Webots 視窗
        {
            "source": "/tmp/.X11-unix",
            "target": "/tmp/.X11-unix",
            "type": "bind"
        },
        // 3. Mount .Xauthority for X11 authentication
        {
            "source": "${localEnv:HOME}/.Xauthority",
            "target": "/root/.Xauthority",
            "type": "bind"
        },
        // 4. 掛載 Git 設定 (保持唯讀以保護宿主機)
        {
            "source": "${localEnv:HOME}/.gitconfig",
            "target": "/root/.gitconfig",
            "type": "bind"
        },
        // 5. 掛載 SSH 金鑰 (唯讀)，對齊 launch.sh。當 ~/.ssh 不存在時 VS Code 會忽略
        {
            "source": "${localEnv:HOME}/.ssh",
            "target": "/root/.ssh",
            "type": "bind",
            "readonly": true
        }
    ],
    // 環境變數設定
    "containerEnv": {
        // 顯示輸出
        "DISPLAY": "${localEnv:DISPLAY}",
        "XAUTHORITY": "/root/.Xauthority",
        // 編碼 / 區域設定（對齊 launch.sh）
        "LANG": "C.UTF-8",
        "LC_ALL": "C.UTF-8",
        "TERM": "xterm-256color",
        // ROS_DOMAIN_ID — devcontainer 預設使用 0，避免與 launch.sh（UID%230）的容器起衝突
        // 若需自訂請修改為與 launch.sh 相同的公式
        "ROS_DOMAIN_ID": "0",
        // NVIDIA GPU — 核心 flags
        "NVIDIA_VISIBLE_DEVICES": "all",
        "NVIDIA_DRIVER_CAPABILITIES": "all",
        // NVIDIA PRIME Render Offload（Intel iGPU + NVIDIA dGPU 雙顯卡必要）
        // 沒有這些變數 OpenGL 會走 Intel/Mesa → llvmpipe（CPU 軟體渲染）
        "__GLX_VENDOR_LIBRARY_NAME": "nvidia",
        "__NV_PRIME_RENDER_OFFLOAD": "1",
        "__VK_LAYER_NV_optimus": "NVIDIA_only",
        "LIBGL_ALWAYS_INDIRECT": "0",
        // Qt 顯示設定
        // QT_QPA_PLATFORM 使用 xcb（容器內無 Wayland）
        "QT_QPA_PLATFORM": "xcb",
        "QT_X11_NO_MITSHM": "1",
        // 注意：移除 QT_XCB_GL_INTEGRATION，部分版本會強迫 Qt 用 EGL（而非 GLX）
        //       在 NVIDIA PRIME 環境下會繞過 __GLX_VENDOR_LIBRARY_NAME 的設定
        // 注意：移除 QT_DEBUG_PLUGINS，避免每次開終端都倒出大量 plugin debug 資訊
        // Webots 相關
        "WEBOTS_HOME": "/usr/local/webots",
        // Git safe.directory（對齊 launch.sh）
        "GIT_CONFIG_COUNT": "1",
        "GIT_CONFIG_KEY_0": "safe.directory",
        "GIT_CONFIG_VALUE_0": "*"
    },
    // postCreateCommand：
    //   1. 設定 git safe.directory
    //   2. 修正 /dev/nvidia* 權限（避免 Webots 無法存取 GPU）
    //   3. 編譯安裝 grpc_core 到 /opt/corgi/install
    //   4. 更新 ldconfig 索引
    "postCreateCommand": "git config --system --add safe.directory '*' && chmod 666 /dev/nvidia* /dev/nvidia-caps/* 2>/dev/null || true && cd /root/corgi_ws/grpc_core && mkdir -p build && cd build && cmake .. -DCMAKE_INSTALL_PREFIX=/opt/corgi/install -DCMAKE_BUILD_TYPE=Release > /dev/null && make -j$(nproc) > /dev/null && make install > /dev/null && ldconfig && echo '\\n✅ grpc_core installed. Run: source /root/corgi_ws/corgi_ros2_ws/install/setup.zsh'",
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "zsh",
                "terminal.integrated.profiles.linux": {
                    "zsh": {
                        "path": "zsh",
                        "args": [
                            "-l"
                        ]
                    }
                }
            }
        }
    },
    "remoteUser": "root"
}
