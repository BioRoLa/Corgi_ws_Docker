{
    "name": "Corgi System Development",
    "image": "starlee0514/corgi_ros2_pack_and_go:latest",
    "runArgs": ["--gpus=all", "--net=host", "--privileged"],
    "mounts": [
        "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind",
        // 修正：移除 readonly，或者保留 readonly 但不要在後端指令執行 git config
        "source=${localEnv:HOME}/.gitconfig,target=/root/.gitconfig,type=bind"
    ],
    "workspaceFolder": "/root/corgi_ws",
    // 修正：移除 git config 指令，避免衝突
    "postCreateCommand": "cd /root/corgi_ws/grpc_core && mkdir -p build && cd build && cmake .. -DCMAKE_INSTALL_PREFIX=/opt/corgi/install && make -j$(nproc) && make install && ldconfig",
    
    // 預裝 VS Code 插件
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-python.python",
                "ms-iot.vscode-ros",
                "mhutchie.git-graph",
                "christian-kohler.path-intellisense"
            ]
        }
    },

    "remoteUser": "root"
}