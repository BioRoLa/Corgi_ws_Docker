{
    "name": "Corgi ROS 2 Development (Pack & Go)",
    "image": "starlee0514/corgi_ros2_pack_and_go:latest",
    // 啟動參數：對齊你的 launch.sh，包含 GPU 與 X11 支援
    "runArgs": [
        "--gpus=all",
        "--net=host",
        "--privileged",
        "--name",
        "corgi_dev_${localEnv:USER}"
    ],
    // 設置容器內的工作目錄
    "workspaceFolder": "/root/corgi_ws/corgi_ros2_ws",
    // 掛載設定
    "mounts": [
        // 1. 將目前的母倉庫掛載到容器內的 /root/corgi_ws
        {
            "source": "${localWorkspaceFolder}",
            "target": "/root/corgi_ws",
            "type": "bind"
        },
        // 2. 掛載 X11 Socket 以啟動 Webots 視窗
        {
            "source": "/tmp/.X11-unix",
            "target": "/tmp/.X11-unix",
            "type": "bind"
        },
        // 3. Mount .Xauthority for X11 authentication
        {
            "source": "${localEnv:HOME}/.Xauthority",
            "target": "/root/.Xauthority",
            "type": "bind"
        },
        // 4. 掛載 Git 設定 (保持唯讀以保護宿主機)
        {
            "source": "${localEnv:HOME}/.gitconfig",
            "target": "/root/.gitconfig",
            "type": "bind"
        }
    ],
    // 環境變數設定
    "containerEnv": {
        "DISPLAY": "${localEnv:DISPLAY}",
        "XAUTHORITY": "/root/.Xauthority",
        "NVIDIA_VISIBLE_DEVICES": "all",
        "NVIDIA_DRIVER_CAPABILITIES": "all",
        "__GLX_VENDOR_LIBRARY_NAME": "nvidia",
        "__NV_PRIME_RENDER_OFFLOAD": "1",
        "__VK_LAYER_NV_optimus": "NVIDIA_only",
        "GIT_CONFIG_COUNT": "1",
        "GIT_CONFIG_KEY_0": "safe.directory",
        "GIT_CONFIG_VALUE_0": "*",
        "QT_QPA_PLATFORM": "xcb",
        "QT_DEBUG_PLUGINS": "1",
        "QT_X11_NO_MITSHM": "1",
        "LIBGL_ALWAYS_INDIRECT": "0",
        "QT_GRAPHICSSYSTEM": "native",
        "QT_XCB_GL_INTEGRATION": "xcb_egl"
    },
    // 只執行編譯，不執行會失敗的 git config
    "postCreateCommand": "git config --system --add safe.directory '*' && cd /root/corgi_ws/grpc_core && mkdir -p build && cd build && cmake .. -DCMAKE_INSTALL_PREFIX=/opt/corgi/install && make -j$(nproc) && make install && ldconfig",
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "zsh"
            }
        }
    },
    "remoteUser": "root"
}